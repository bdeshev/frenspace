# Frenspace Environment Configuration
# Copy this to .env and fill in your values

# =============================================================================
# Better Auth Configuration
# =============================================================================

# Random secret for JWT signing and session encryption
# Generate with: openssl rand -base64 32
export BETTER_AUTH_SECRET="your-super-secret-random-string-min-32-chars"

# Your application's base URL
# Development: http://localhost:3000
# Production: https://yourdomain.com
export BETTER_AUTH_URL="http://localhost:3000"

# =============================================================================
# Discord OAuth Configuration
# =============================================================================

# From Discord Developer Portal → Applications → OAuth2
# https://discord.com/developers/applications
export DISCORD_CLIENT_ID="your-discord-app-client-id"
export DISCORD_CLIENT_SECRET="your-discord-app-client-secret"

# =============================================================================
# Database Configuration
# =============================================================================

# SQLite database file path
# Relative to project root, or absolute path
export DATABASE_URL="./data/frenspace.db"

# =============================================================================
# Server Configuration (optional)
# =============================================================================

# Port to run the server on (defaults to 3000)
export PORT="3000"
